# https://dart.dev/guides/libraries/private-files
# Standard Flutter .gitignore file

# Tooling and build outputs
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
.metadata

# Web build output and icons/compiled files if generated
build/web/

# Android related
**/android/local.properties
**/android/key.properties
**/android/app/src/main/res/values/strings.xml
**/android/app/google-services.json

# iOS Firebase config (contains API keys — never commit)
**/ios/Runner/GoogleService-Info.plist

# Firebase Admin SDK service account key — a real secret, never commit
backend/serviceAccountKey.json

# iOS related
**/ios/Flutter/.flutter-plugins
**/ios/Flutter/.flutter-plugins-dependencies
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/GeneratedPluginRegistrant.h
**/ios/Runner/GeneratedPluginRegistrant.m

# IDEs and editors
.idea/
*.iml
*.ipr
*.iws
.vscode/
.history/

# Operating System files
.DS_Store
Thumbs.db
desktop.ini
AI_COWORKER/
*.env
.env
backend/.env

# Local development configurations
lib/config.dart

# Python bytecode compilation artifacts
**/__pycache__/
**/*.pyc